# AETHER Bot Configuration

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Database
DATABASE_PATH=./data/aether.db

# Mining Configuration
MINING_RATE=1
MINING_INTERVAL_HOURS=4
MAX_OFFLINE_HOURS=8
BOOST_MULTIPLIER=2

# AI Configuration
OLLAMA_HOST=http://localhost:11434
DEFAULT_MODEL=gemma2

# TON Configuration (for future DEX integration)
TON_API_KEY=
TON_NETWORK=testnet

# Referral System
REFERRAL_BONUS=0.1
REFERRAL_BONUS_MINING=0.05

# Limits
DAILY_AI_TASKS=10
DAILY_MINING_SESSIONS=6
MAX_CLAN_SIZE=50